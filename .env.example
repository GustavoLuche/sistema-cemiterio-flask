# PostgreSQL Connection String (Render ou outra hospedagem)
# Formato: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/cemiterio_db

# Flask Configuration
FLASK_DEBUG=True
FLASK_ENV=development
PORT=5000

# Para produção, mude para:
# FLASK_ENV=production
# FLASK_DEBUG=False
